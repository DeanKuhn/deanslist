---
// Skills.astro
// Clean grid of skill categories. No progress bars.

const skills = [
  {
    category: 'Languages',
    items: ['Python', 'SQL'],
  },
  {
    category: 'Data & Storage',
    items: ['PostgreSQL', 'Snowflake', 'dbt Core', 'pandas', 'PyArrow', 'Parquet'],
  },
  {
    category: 'Ingestion & APIs',
    items: ['FastAPI', 'REST APIs', 'Playwright', 'asyncio / httpx'],
  },
  {
    category: 'ML & Modeling',
    items: ['LightGBM', 'scikit-learn', 'VADER sentiment'],
  },
  {
    category: 'Infrastructure',
    items: ['GitHub Actions', 'Neon (cloud Postgres)', 'Git', 'Linux / WSL', 'AWS (exposure)'],
  },
  {
    category: 'Concepts',
    items: ['Medallion architecture', 'Data modeling', 'dbt staging/mart/metrics', 'ML inference serving', 'Genetic algorithms'],
  },
];
---

<section id="skills">
  <div class="container">
    <div class="section-header">
      <span class="section-label mono muted">02 / skills</span>
      <h2 class="section-title">Technical Stack</h2>
    </div>

    <div class="skills-grid">
      {skills.map((group) => (
        <div class="skill-group">
          <div class="group-label mono muted">{group.category}</div>
          <ul class="group-items">
            {group.items.map((item) => (
              <li class="skill-item">{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-header {
    margin-bottom: var(--space-xl);
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.5;
    display: block;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    letter-spacing: -0.02em;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--space-lg);
  }

  .skill-group {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: var(--space-md);
  }

  .group-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    opacity: 0.6;
  }

  .group-items {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-item {
    font-size: 0.9rem;
    color: var(--text);
    padding-left: 0.75rem;
    position: relative;
  }

  .skill-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 3px;
    height: 3px;
    background: var(--accent);
    border-radius: 50%;
  }
</style>
