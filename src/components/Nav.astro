---
// Nav.astro
// Minimal fixed nav: name on left, anchor links on right.
---

<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-name mono">dean kuhn</a>
    <ul class="nav-links">
      <li><a href="#projects">projects</a></li>
      <li><a href="#skills">skills</a></li>
      <li><a href="#about">about</a></li>
      <li>
        <a href="mailto:dakuhn1138@gmail.com" class="nav-cta">get in touch</a>
      </li>
    </ul>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: rgba(14, 15, 17, 0.85);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.5rem;
  }

  .nav-name {
    font-size: 0.875rem;
    color: var(--text);
    letter-spacing: 0.05em;
  }

  .nav-name:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav-links {
    list-style: none;
    display: flex;
    gap: var(--space-lg);
    align-items: center;
  }

  .nav-links a {
    font-size: 0.8125rem;
    font-family: var(--font-mono);
    color: var(--muted);
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  .nav-cta {
    color: var(--accent) !important;
    border: 1px solid var(--accent-dim);
    padding: 0.3rem 0.75rem;
    border-radius: var(--radius);
    transition: background 0.15s !important;
  }

  .nav-cta:hover {
    background: var(--accent-dim);
  }

  /* Mobile: hide nav links, show hamburger (Claude Code: implement toggle) */
  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
  }
</style>
