---
import ProjectLayout from '../layouts/Project.astro';
import { projects } from '../data/projects';
import { fetchKitchenSync, fetchMusicPipeline, fetchWgups } from '../lib/fetchProjectData';
import { buildWgupsRouteVisual } from '../lib/wgupsRoute';
import { Icon } from 'astro-icon/components';

const [kitchenResult, musicResult, wgupsResult] = await Promise.all([
  fetchKitchenSync(),
  fetchMusicPipeline(),
  fetchWgups(),
]);

const kitchenData = kitchenResult.state === 'ok' ? kitchenResult.data : null;
const musicData = musicResult.state === 'ok' ? musicResult.data : null;
const wgupsData = wgupsResult.state === 'ok' ? wgupsResult.data : null;
const wgupsRoute = wgupsData ? buildWgupsRouteVisual(wgupsData) : null;

// Live status line
const timestamps: string[] = [];
if (kitchenData) {
  const last = kitchenData.daily.at(-1);
  if (last) timestamps.push(last.date);
}
if (musicData?.summary.latest_snapshot) {
  timestamps.push(musicData.summary.latest_snapshot);
}
if (wgupsData?.run_timestamp) {
  timestamps.push(wgupsData.run_timestamp.slice(0, 10));
}
timestamps.sort((a, b) => (b > a ? 1 : -1));
const lastRun = timestamps[0] ?? null;

const liveProjects = projects.filter((p) => p.status === 'live').length + 1; // + WGUPS (live route data; project itself is complete)
const devProjects = 1; // Market Cynic

// KitchenSync card metrics
const mlServiceLevel = kitchenData
  ? kitchenData.cumulative.ml_avg_service_level.toFixed(1)
  : null;
const baseServiceLevel = kitchenData
  ? kitchenData.cumulative.base_avg_service_level.toFixed(1)
  : null;
const daysRun = kitchenData?.cumulative.days_run ?? null;
const wasteDelta =
  kitchenData != null
    ? (kitchenData.cumulative.ml_avg_waste_pct - kitchenData.cumulative.baseline_avg_waste_pct).toFixed(1)
    : null;

// KitchenSync sparkline — last 14 days ML service level
const sparkValues = kitchenData
  ? kitchenData.daily.slice(-14).map((d) =>
      (d.ml.units_sold / (d.ml.units_sold + d.ml.stockouts)) * 100
    )
  : [];
const sparkMin = sparkValues.length ? Math.min(...sparkValues) : 0;
const sparkMax = sparkValues.length ? Math.max(...sparkValues) : 100;
const sparkRange = sparkMax - sparkMin || 1;
const sparkW = 120;
const sparkH = 28;
const sparkPath = sparkValues
  .map((v, i) => {
    const x = (i / (sparkValues.length - 1)) * sparkW;
    const y = sparkH - ((v - sparkMin) / sparkRange) * sparkH;
    return `${i === 0 ? 'M' : 'L'} ${x.toFixed(1)} ${y.toFixed(1)}`;
  })
  .join(' ');

// Music card metrics
const artistCount = musicData
  ? Number(musicData.summary.artist_count).toLocaleString()
  : null;
const weeksTracked = musicData?.summary.weeks_tracked ?? null;
const indieTier = musicData?.growth_by_tier.find((t) => t.tier === 'indie');
const mainstreamTier = musicData?.growth_by_tier.find((t) => t.tier === 'mainstream');
const indieP90 = indieTier ? indieTier.p90_pct_growth.toFixed(1) : null;
const mainstreamP90 = mainstreamTier ? mainstreamTier.p90_pct_growth.toFixed(1) : null;
---

<ProjectLayout description="Data engineer. Milwaukee, WI.">

  <!-- Nav bar -->
  <header class="nav-bar">
    <div class="container nav-inner">
      <span class="nav-brand mono">dean's list</span>
      <nav class="nav-links mono">
        <a href="https://github.com/DeanKuhn" target="_blank" rel="noopener">github</a>
        <a href="https://linkedin.com/in/dean-kuhn-565249380" target="_blank" rel="noopener">linkedin</a>
        <a href="/Dean_Kuhn_Resume.pdf" target="_blank" rel="noopener">resume</a>
      </nav>
    </div>
  </header>

  <main>

    <!-- Hero -->
    <section class="hero container">
      <div class="hero-eyebrow mono muted">
        <span class="status-dot"></span>
        analytics engineer · milwaukee, wi
      </div>
      <h1 class="hero-headline">
        Dean Kuhn
      </h1>
      <p class="hero-sub muted">
        <span class="hero-sub-line">I work across the full data lifecycle. The pipelines, transformations, warehousing, ML, and dashboards that make it usable.</span>
        <span class="hero-sub-line hero-sub-line--gap">WGU CS graduate (May 2026), looking for a junior data engineering, analytics engineering, or data analysis role where I can own a problem from raw input to shipped result.</span>
      </p>

      {lastRun && (
        <div class="hero-status mono muted">
          <Icon name="tabler:activity" class="status-icon" />
          Last pipeline run: {lastRun}
          &nbsp;·&nbsp;
          {liveProjects} project{liveProjects !== 1 ? 's' : ''} live, {devProjects} in development
        </div>
      )}

      <div class="hero-ctas">
        <a href="#projects" class="btn-primary">
          View projects
          <Icon name="tabler:arrow-down" class="btn-icon" />
        </a>
        <a href="/Dean_Kuhn_Resume.pdf" target="_blank" rel="noopener" class="btn-secondary mono">
          Resume (PDF)
          <Icon name="tabler:external-link" class="btn-icon" />
        </a>
      </div>
    </section>

    <!-- Stat cards grid -->
    <section id="projects" class="cards-section container">
      <div class="section-label mono muted">projects</div>

      <div class="cards-grid">

        <!-- KitchenSync -->
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">KitchenSync</div>
              <div class="card-subtitle mono muted">data engineering · live</div>
            </div>
            <span class="live-badge mono">● live</span>
          </div>

          <div class="card-body">
            {kitchenData ? (
              <>
                <div class="card-metric">
                  <span class="metric-value accent">{mlServiceLevel}%</span>
                  <span class="metric-label mono muted">ML service level</span>
                </div>
                <div class="card-metric-row">
                  <div>
                    <span class="metric-sm">{baseServiceLevel}%</span>
                    <span class="metric-sm-label mono muted">baseline</span>
                  </div>
                  <div>
                    <span class="metric-sm">+{wasteDelta}pp</span>
                    <span class="metric-sm-label mono muted">waste trade-off</span>
                  </div>
                  <div>
                    <span class="metric-sm">{daysRun}</span>
                    <span class="metric-sm-label mono muted">days run</span>
                  </div>
                </div>
                {sparkValues.length > 1 && (
                  <div class="sparkline-wrap">
                    <div class="sparkline-label mono muted">ML service level · last {sparkValues.length} days</div>
                    <svg width={sparkW} height={sparkH} class="sparkline">
                      <path d={sparkPath} fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </div>
                )}
              </>
            ) : (
              <div class="card-omitted mono muted">live data unavailable at build time</div>
            )}
          </div>

          <div class="card-footer">
            <span class="card-tagline muted">ML forecasting for a Kwik Trip-style kitchen production system</span>
            <a href="/projects/kitchensync" class="card-link mono accent">
              View project <Icon name="tabler:arrow-right" class="link-icon" />
            </a>
          </div>
        </div>

        <!-- Music Growth Pipeline -->
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Music Growth Pipeline</div>
              <div class="card-subtitle mono muted">data engineering · live</div>
            </div>
            <span class="live-badge mono">● live</span>
          </div>

          <div class="card-body">
            {musicData ? (
              <>
                <div class="card-metric">
                  <span class="metric-value accent">{artistCount}</span>
                  <span class="metric-label mono muted">artists tracked · {weeksTracked} weeks</span>
                </div>
                {indieTier && mainstreamTier && (
                  <div class="tier-bars">
                    <div class="tier-row">
                      <span class="tier-label mono muted">mainstream P90</span>
                      <div class="tier-bar-track">
                        <div class="tier-bar" style={`width: ${Math.min(100, (mainstreamTier.p90_pct_growth / (indieTier.p90_pct_growth || 1)) * 100)}%`}></div>
                      </div>
                      <span class="tier-val mono">{mainstreamP90}%</span>
                    </div>
                    <div class="tier-row">
                      <span class="tier-label mono muted">indie P90</span>
                      <div class="tier-bar-track">
                        <div class="tier-bar tier-bar--accent" style="width: 100%"></div>
                      </div>
                      <span class="tier-val mono accent">{indieP90}%</span>
                    </div>
                  </div>
                )}
              </>
            ) : (
              <div class="card-omitted mono muted">live data unavailable at build time</div>
            )}
          </div>

          <div class="card-footer">
            <span class="card-tagline muted">Underground artists grow 3× faster than mainstream in listener %</span>
            <a href="/projects/music-growth-pipeline" class="card-link mono accent">
              View project <Icon name="tabler:arrow-right" class="link-icon" />
            </a>
          </div>
        </div>

        <!-- WGUPS Package Routing — stub -->
        <div class="card">
          <div class="card-header">
            <div>
              <div class="card-title">Package Delivery Routing</div>
              <div class="card-subtitle mono muted">algorithms · complete</div>
            </div>
            <span class="complete-badge mono">✓ complete</span>
          </div>

          <div class="card-body">
            {wgupsData ? (
              <>
                <div class="card-metric">
                  <span class="metric-value accent">{wgupsData.final_score.toFixed(1)}</span>
                  <span class="metric-label mono muted">final fitness score · {wgupsData.parameters.generations} generations</span>
                </div>
                <div class="card-metric-row">
                  <div>
                    <span class="metric-sm">{wgupsData.parameters.packages}</span>
                    <span class="metric-sm-label mono muted">packages</span>
                  </div>
                  <div>
                    <span class="metric-sm">{wgupsData.parameters.trucks}</span>
                    <span class="metric-sm-label mono muted">trucks</span>
                  </div>
                  <div>
                    <span class="metric-sm">{wgupsData.parameters.refrig_trucks}</span>
                    <span class="metric-sm-label mono muted">refrigerated</span>
                  </div>
                </div>
                {wgupsRoute && wgupsRoute.stops.length > 0 && (
                  <div class="route-anim" aria-hidden="true">
                    <svg viewBox="0 0 200 200" class="route-svg route-svg--wgups">
                      {wgupsRoute.truckPaths.map((t) => (
                        <path id={`wgups-path-${t.truckId}`} class:list={['route', `route-c${t.colorIndex}`]} d={t.d} fill="none" style={`stroke-width: ${wgupsRoute!.strokeWidth}`} />
                      ))}
                      {wgupsRoute.showNodes && wgupsRoute.stops.map((s) => (
                        <circle class="node" cx={s.x} cy={s.y} r={wgupsRoute!.nodeRadius} />
                      ))}
                      <circle class="hub-node" cx={wgupsRoute.hub.x} cy={wgupsRoute.hub.y} r="5" />
                      {wgupsRoute.truckPaths.map((t, i) => (
                        <circle class:list={['truck', `truck-c${t.colorIndex}`]} r={wgupsRoute!.truckRadius}>
                          <animateMotion dur={`${4 + (i % 3)}s`} begin={`${(i * 0.6).toFixed(1)}s`} repeatCount="indefinite" calcMode="linear">
                            <mpath href={`#wgups-path-${t.truckId}`} />
                          </animateMotion>
                        </circle>
                      ))}
                    </svg>
                    <div class="stub-note mono muted">
                      {wgupsData.parameters.trucks} trucks · {wgupsRoute.stops.length} stops · run {wgupsData.run_timestamp.slice(0, 10)}
                    </div>
                  </div>
                )}
              </>
            ) : (
              <div class="card-omitted mono muted">live data unavailable at build time</div>
            )}
          </div>

          <div class="card-footer">
            <span class="card-tagline muted">GA solves vehicle routing + loading simultaneously in one chromosome</span>
            <a href="/projects/package-router" class="card-link mono accent">
              View project <Icon name="tabler:arrow-right" class="link-icon" />
            </a>
          </div>
        </div>

        <!-- Market Cynic — pending -->
        <div class="card card--pending">
          <div class="card-header">
            <div>
              <div class="card-title">Market Cynic Pipeline</div>
              <div class="card-subtitle mono muted">data engineering</div>
            </div>
            <span class="dev-badge mono">◌ in development</span>
          </div>

          <div class="card-body card-body--pending">
            <div class="pending-label mono muted">v2 in development</div>
            <p class="pending-desc muted">
              Rebuilding on Databricks, Azure Data Lake Storage Gen2, Delta Lake, PySpark, and Apache Airflow. Shifting from Reddit sentiment to S&P 500 breakout signal detection. v1's automated runs are paused after Reddit shut down the public .json endpoints.
            </p>
          </div>

          <div class="card-footer">
            <span class="card-tagline muted">Bronze→Silver→Gold Delta Lake pipeline detecting S&P 500 breakout signals from price and volume data</span>
            <a href="/projects/market-cynic-pipeline" class="card-link mono muted">
              See architecture <Icon name="tabler:arrow-right" class="link-icon" />
            </a>
          </div>
        </div>

      </div>
    </section>

    <!-- About -->
    <section id="about" class="about-section container">
      <div class="section-label mono muted">about</div>

      <div class="about-inner">
        <div class="about-text">
          <p>
            CS graduate (WGU, May 2026) based in the Milwaukee area. Looking for roles where the work involves getting data from raw to useful. Engineering the pipeline, modeling the warehouse, or doing the analysis downstream.
          </p>
          <p>
            My projects run the full stack on purpose: ingestion, transformation, warehousing, ML forecasting,
            and dashboarding. Understanding why a pipeline breaks is easier when you've written the transformation layer yourself.
          </p>
          <div class="about-links mono">
            <a href="mailto:dakuhn1138@gmail.com">
              <Icon name="tabler:mail" class="about-icon" />
              dakuhn1138@gmail.com
            </a>
            <a href="https://github.com/DeanKuhn" target="_blank" rel="noopener">
              <Icon name="tabler:brand-github" class="about-icon" />
              github
            </a>
            <a href="https://linkedin.com/in/dean-kuhn-565249380" target="_blank" rel="noopener">
              <Icon name="tabler:brand-linkedin" class="about-icon" />
              linkedin
            </a>
          </div>
        </div>

        <div class="skills">
          <div class="skills-label mono muted">stack</div>
          <div class="skill-groups">
            {[
              { label: 'languages', items: ['Python', 'SQL'] },
              { label: 'data & storage', items: ['PostgreSQL', 'Snowflake', 'dbt Core', 'pandas', 'FastAPI'] },
              { label: 'ml', items: ['LightGBM', 'scikit-learn'] },
              { label: 'viz', items: ['Streamlit', 'Power BI'] },
              { label: 'infra', items: ['GitHub Actions', 'AWS EC2', 'Docker', 'Linux/WSL'] },
              { label: 'learning', items: ['Databricks', 'Azure Data Lake Storage Gen2', 'Delta Lake', 'PySpark', 'Apache Airflow'] },
            ].map((group) => (
              <div class="skill-group">
                <div class="skill-group-label mono muted">{group.label}</div>
                <div class="skill-pills">
                  {group.items.map((s) => (
                    <span class="pill mono">{s}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <footer class="site-footer container mono muted">
      <span>&copy; 2026 deanslist.dev</span>
      <span>Milwaukee, WI · open to remote</span>
    </footer>

  </main>

</ProjectLayout>

<style>
  /* Nav */
  .nav-bar {
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand {
    font-size: 0.875rem;
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    font-size: 0.8125rem;
  }

  .nav-links a {
    color: var(--muted);
    transition: color 0.15s;
  }

  .nav-links a:hover {
    color: var(--text);
    text-decoration: none;
  }

  /* Hero */
  .hero {
    padding-top: 5rem;
    padding-bottom: 5rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #4ade80;
    box-shadow: 0 0 6px #4ade80;
    flex-shrink: 0;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 1.25rem;
  }

  .hero-sub {
    font-size: 1.0625rem;
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 1.5rem;
  }

  .hero-sub-line {
    display: block;
  }

  .hero-sub-line--gap {
    margin-top: 0.5rem;
  }

  .hero-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    margin-bottom: 2rem;
  }

  .status-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .hero-ctas {
    display: flex;
    gap: 0.875rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--accent);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    transition: opacity 0.15s;
  }

  .btn-primary:hover {
    opacity: 0.88;
    text-decoration: none;
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 0.8125rem;
    padding: 0.625rem 1.25rem;
    border-radius: var(--radius);
    transition: border-color 0.15s, color 0.15s;
  }

  .btn-secondary:hover {
    border-color: var(--muted);
    color: var(--text);
    text-decoration: none;
  }

  .btn-icon {
    width: 1rem;
    height: 1rem;
  }

  /* Cards */
  .cards-section {
    padding-top: 4rem;
    padding-bottom: 4rem;
  }

  .section-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 1rem;
  }

  .card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    display: flex;
    flex-direction: column;
    transition: border-color 0.15s;
  }

  .card:hover {
    border-color: #3d4148;
  }

  .card--pending {
    opacity: 0.75;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1.25rem 1.25rem 0;
    gap: 0.5rem;
  }

  .card-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    margin-bottom: 0.2rem;
  }

  .card-subtitle {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
  }

  .live-badge {
    font-size: 0.625rem;
    color: #4ade80;
    letter-spacing: 0.04em;
    white-space: nowrap;
    margin-top: 0.1rem;
  }

  .complete-badge {
    font-size: 0.625rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    white-space: nowrap;
    margin-top: 0.1rem;
  }

  .dev-badge {
    font-size: 0.625rem;
    color: var(--muted);
    letter-spacing: 0.04em;
    white-space: nowrap;
    margin-top: 0.1rem;
  }

  .card-body {
    padding: 1.25rem;
    flex: 1;
  }

  .card-omitted {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 1rem 0;
  }

  .card-body--pending {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .pending-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .pending-desc {
    font-size: 0.8125rem;
    line-height: 1.65;
  }

  .card-metric {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    margin-bottom: 1rem;
  }

  .metric-value {
    font-family: var(--font-mono);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .metric-label {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .card-metric-row {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 1rem;
  }

  .metric-sm {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text);
    display: block;
  }

  .metric-sm-label {
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    display: block;
    margin-top: 0.125rem;
  }

  .sparkline-wrap {
    margin-top: 0.5rem;
  }

  .sparkline-label {
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.375rem;
  }

  .sparkline {
    display: block;
  }

  /* Tier bars */
  .tier-bars {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    margin-top: 0.5rem;
  }

  .tier-row {
    display: grid;
    grid-template-columns: 90px 1fr 50px;
    align-items: center;
    gap: 0.625rem;
  }

  .tier-label {
    font-size: 0.625rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .tier-bar-track {
    height: 4px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
  }

  .tier-bar {
    height: 100%;
    background: var(--muted);
    border-radius: 2px;
    transition: width 0.3s;
  }

  .tier-bar--accent {
    background: var(--accent);
  }

  .tier-val {
    font-size: 0.75rem;
    text-align: right;
  }

  /* WGUPS route animation */
  .route-anim {
    text-align: center;
    width: 100%;
  }

  .route-svg {
    width: 100%;
    max-width: 200px;
    height: 80px;
    display: block;
    margin: 0 auto 0.5rem;
  }

  .route-svg--wgups {
    max-width: 160px;
    height: 160px;
  }

  .node {
