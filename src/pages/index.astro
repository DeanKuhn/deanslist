---
import Craigslist from '../layouts/Craigslist.astro';
import { projects } from '../data/projects';

// Group projects by category
const categories = [...new Set(projects.map((p) => p.category))];
---

<style>
  .mobile-header { display: none; }
  @media (max-width: 600px) {
    .mobile-header { display: block; }
    .sidebar-col { display: none; }
    .gap-col { display: none; }
  }
</style>

<Craigslist>
  <div class="mobile-header" style="padding: 8px 12px 10px; border-bottom: 1px solid #ccc; margin-bottom: 10px;">
    <div style="font-size: 20px; font-weight: bold; color: #800000; letter-spacing: -1px;">dean's list</div>
    <div style="font-size: 11px; color: #666; margin-top: 1px;">milwaukee, wi</div>
    <div style="font-size: 12px; margin-top: 5px; line-height: 1.8;">
      <a href="mailto:dakuhn1138@gmail.com">contact</a> &nbsp;·&nbsp;
      <a href="https://github.com/DeanKuhn" target="_blank">github</a> &nbsp;·&nbsp;
      <a href="https://linkedin.com/in/dean-kuhn-565249380" target="_blank">linkedin</a> &nbsp;·&nbsp;
      <a href="/Dean_Kuhn_Resume.pdf" target="_blank">resume</a>
    </div>
  </div>
  <table width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
      <td width="16" valign="top" class="gap-col"></td>

      <!-- Left column: branding + nav -->
      <td width="200" valign="top" style="padding-right: 20px; border-right: 1px solid #ccc;" class="sidebar-col">
        <div style="text-align: center; margin-bottom: 16px;">
          <div style="font-size: 26px; font-weight: bold; color: #800000; letter-spacing: -1px;">
            dean's list
          </div>
          <div style="font-size: 11px; color: #666; margin-top: 2px;">
            milwaukee, wi
          </div>
        </div>

        <hr style="border: none; border-top: 1px solid #ccc; margin: 8px 0;" />

        <div style="font-size: 12px; line-height: 1.8; margin: 8px 0;">
          <a href="#about">about</a><br />
          <a href="mailto:dakuhn1138@gmail.com">contact</a><br />
          <a href="https://github.com/DeanKuhn" target="_blank">github</a><br />
          <a href="https://linkedin.com/in/dean-kuhn-565249380" target="_blank">linkedin</a><br />
          <a href="/Dean_Kuhn_Resume.pdf" target="_blank">resume</a>
        </div>

        <hr style="border: none; border-top: 1px solid #ccc; margin: 8px 0;" />

        <div style="font-size: 11px; color: #666; line-height: 1.7;">
          <div>B.S. Computer Science</div>
          <div>WGU · May 2026</div>
          <br />
          <div>dbt Fundamentals</div>
          <div>ITIL 4 Foundation</div>
        </div>
      </td>

      <td width="16" valign="top"></td>

      <!-- Main column: project listings -->
      <td valign="top">
        <table width="100%" cellpadding="0" cellspacing="0">
          <tr>
            <td>
              <div style="font-size: 13px; font-weight: bold; margin-bottom: 12px;">
                portfolio — projects by <a href="#about">dean kuhn</a>
              </div>

              {categories.map((cat) => (
                <div style="margin-bottom: 20px;">
                  <div style="font-size: 13px; font-weight: bold; margin-bottom: 6px; color: #800000;">
                    {cat}
                  </div>
                  <table cellpadding="0" cellspacing="0" style="width: 100%;">
                    {projects
                      .filter((p) => p.category === cat)
                      .map((p) => (
                        <tr>
                          <td style="padding: 1px 0; vertical-align: top; white-space: nowrap; padding-right: 8px;">
                            <span style="color: #666; font-size: 12px;">
                              {p.status === 'live' ? '●' : p.status === 'paused' ? '◌' : '✓'}
                            </span>
                          </td>
                          <td style="padding: 1px 0;">
                            <a href={`/projects/${p.slug}`} style="font-size: 13px;">
                              {p.title}
                            </a>
                            <span style="color: #666; font-size: 12px;"> — {p.tagline}</span>
                          </td>
                        </tr>
                      ))}
                  </table>
                </div>
              ))}

              <!-- Stack callout -->
              <div style="margin-top: 16px; margin-bottom: 20px;">
                <div style="font-size: 13px; font-weight: bold; margin-bottom: 6px; color: #800000;">
                  skills
                </div>
                <div style="font-size: 12px; color: #444; line-height: 1.8;">
                  <span style="font-weight: bold;">languages:</span> Python, SQL<br />
                  <span style="font-weight: bold;">data &amp; storage:</span> PostgreSQL, Snowflake, dbt Core, pandas, PyArrow<br />
                  <span style="font-weight: bold;">ingestion:</span> FastAPI, REST APIs, Playwright, asyncio/httpx<br />
                  <span style="font-weight: bold;">ml:</span> LightGBM, scikit-learn, VADER sentiment<br />
                  <span style="font-weight: bold;">infra:</span> GitHub Actions, Neon, Git, Linux/WSL, AWS (exposure)<br />
                </div>
              </div>

              <hr style="border: none; border-top: 1px solid #ccc; margin: 12px 0;" />

              <!-- About -->
              <div id="about" style="margin-top: 12px;">
                <div style="font-size: 13px; font-weight: bold; margin-bottom: 6px; color: #800000;">
                  about
                </div>
                <div style="font-size: 12px; color: #444; line-height: 1.8; max-width: 600px;">
                  CS graduate (WGU, May 2026) based in the Milwaukee area.
                  Looking for a junior data engineering role — Milwaukee area preferred, open to remote.
                  Current focus is on pipeline infrastructure: ingestion, transformation, and serving layers
                  that are reliable and maintainable rather than impressive once.
                  <br /><br />
                  I work at Kwik Trip, which is why a kitchen production forecasting system
                  was a natural problem to model.
                  <br /><br />
                  <a href="mailto:dakuhn1138@gmail.com">dakuhn1138@gmail.com</a>
                  &nbsp;·&nbsp;
                  <a href="https://linkedin.com/in/dean-kuhn-565249380" target="_blank">linkedin</a>
                  &nbsp;·&nbsp;
                  <a href="https://github.com/DeanKuhn" target="_blank">github</a>
                  &nbsp;·&nbsp;
                  <a href="/Dean_Kuhn_Resume.pdf" target="_blank">resume (pdf)</a>
                </div>
              </div>

              <hr style="border: none; border-top: 1px solid #ccc; margin: 16px 0;" />

              <div style="font-size: 10px; color: #999;">
                not affiliated with craigslist &nbsp;·&nbsp; milwaukee, wi &nbsp;·&nbsp; 2026
              </div>
            </td>
          </tr>
        </table>
      </td>

      <td width="16" class="gap-col"></td>
    </tr>
  </table>
</Craigslist>
