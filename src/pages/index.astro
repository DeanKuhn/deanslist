---
import Craigslist from '../layouts/Craigslist.astro';
import { projects } from '../data/projects';

// Group projects by category
const categories = [...new Set(projects.map((p) => p.category))];

let pipelineStats: any = null;
let kitchenStats: any = null;

try {
  const r = await fetch('https://raw.githubusercontent.com/DeanKuhn/music-growth-pipeline/main/data/pipeline_stats.json');
  if (r.ok) pipelineStats = await r.json();
} catch {}

try {
  const r = await fetch('https://raw.githubusercontent.com/DeanKuhn/kitchensync/master/data/ab_results.json');
  if (r.ok) kitchenStats = await r.json();
} catch {}

const artistCount = pipelineStats?.summary?.artist_count != null
  ? Number(pipelineStats.summary.artist_count).toLocaleString() : null;
const weeksTracked = pipelineStats?.summary?.weeks_tracked ?? null;
const latestSnapshot = kitchenStats?.daily?.at(-1)?.date ?? null;
const indieP90 = (() => {
  const tier = pipelineStats?.growth_by_tier?.find((t: any) => t.tier === 'indie');
  return tier?.p90_pct_growth != null ? `${tier.p90_pct_growth.toFixed(2)}%` : null;
})();
const mlServiceLevel = kitchenStats?.cumulative?.ml_avg_service_level != null
  ? `${Number(kitchenStats.cumulative.ml_avg_service_level).toFixed(1)}%` : null;
const mlWastePct = kitchenStats?.cumulative?.ml_avg_waste_pct != null
  ? `${Number(kitchenStats.cumulative.ml_avg_waste_pct).toFixed(1)}%` : null;

const showStats = pipelineStats !== null || kitchenStats !== null;
---

