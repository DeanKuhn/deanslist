          <polyline points="236,83 240,90 244,83" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="50" y="90" width="380" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="110" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Population init — capacity-aware seeding</text>
          <line x1="240" y1="130" x2="240" y2="173" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,173 240,180 244,173" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="60" y="180" width="360" height="55" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="200" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Fitness function</text>
