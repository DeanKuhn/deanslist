<style>
  /* Back bar */
  .back-bar {
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  .back-link {
    font-size: 0.8125rem;
    color: var(--muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  /* Page */
  .page {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }

  /* Header */
  .project-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2.5rem;
  }

  .header-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
  }

  .sep { opacity: 0.3; }
  .category { text-transform: uppercase; letter-spacing: 0.12em; }

  .status--live    { color: #4ade80; }
  .status--paused  { color: var(--muted); }
  .status--complete{ color: var(--muted); }

  .project-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .project-tagline {
    font-size: 1rem;
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 1rem;
    color: var(--muted);
  }

  .status-note {
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: var(--bg-card);
    border-left: 2px solid var(--border);
    border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: 1rem;
    max-width: 600px;
  }

  .github-link {
    font-size: 0.875rem;
    display: inline-block;
    margin-top: 0.5rem;
    border: 1px solid var(--accent-dim);
    padding: 0.4rem 0.875rem;
    border-radius: var(--radius);
    transition: background 0.15s;
  }

  .github-link:hover {
    background: var(--accent-dim);
    text-decoration: none;
  }

  /* Diagram frame */
  .diagram-frame {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 3rem;
  }

  .diagram-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 0.85;
  }

  /* Body sections */
  .project-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
    opacity: 0.85;
  }

  .section p {
    color: var(--text);
    font-size: 0.9375rem;
    line-height: 1.8;
    max-width: 700px;
  }

  /* Highlights */
  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .highlights li {
    display: flex;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--text);
    line-height: 1.65;
    max-width: 700px;
  }

  .highlights li .mono {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Challenges */
  .section--challenges p {
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
    color: var(--text);
  }

  /* Tags */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.6875rem;
    color: var(--muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 0.25rem 0.6rem;
    letter-spacing: 0.04em;
  }

  /* A/B Results + Pipeline Stats shared styles */
  .ab-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 3rem;
  }

  .ab-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .ab-days {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .ab-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .ab-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .ab-card-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.25rem;
  }

  .ab-metric {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .ab-value {
    font-family: var(--font-mono);
    font-size: 1.375rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .ab-value.accent {
    color: var(--accent);
  }

  .ab-key {
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .ab-daily {
    border-top: 1px solid var(--border);
    padding-top: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .ab-daily-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 0.85;
  }

  .delta {
    display: block;
    font-size: 0.625rem;
    letter-spacing: 0.04em;
    margin-top: 0.125rem;
    opacity: 0.7;
  }

  .delta--better { color: #4ade80; }
  .delta--worse  { color: var(--muted); }

  .ab-callout {
    font-size: 0.8125rem;
    color: var(--muted);
    border-left: 2px solid var(--accent);
    padding: 0.5rem 0.875rem;
    line-height: 1.6;
  }

  /* Growth list (music pipeline) */
  .growth-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .growth-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 1rem;
    align-items: baseline;
    font-size: 0.8125rem;
    padding: 0.375rem 0;
    border-bottom: 1px solid var(--border);
  }

  .growth-row:last-child {
    border-bottom: none;
  }

  .growth-name {
    color: var(--text);
  }

  .growth-meta {
    font-size: 0.6875rem;
    opacity: 0.5;
  }

  .growth-value {
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  @media (max-width: 480px) {
    .ab-grid { grid-template-columns: 1fr; }
  }

  /* Power BI report preview */
  .report-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 3rem;
  }

  .report-header {
    margin-bottom: 1.25rem;
  }

  .report-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .report-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    transition: border-color 0.15s;
    text-decoration: none;
  }

  .report-card:hover {
    border-color: var(--accent);
    text-decoration: none;
  }

  .report-card-label {
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .report-img {
    width: 100%;
    display: block;
    border-radius: 2px;
    border: 1px solid var(--border);
  }

  @media (max-width: 600px) {
    .report-grid { grid-template-columns: 1fr; }
  }

  /* Page footer */
  .page-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .page-footer a {
    font-size: 0.8125rem;
  }

  /* Live results chart section */
  .live-results-section {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 3rem;
  }

  .live-results-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .live-results-days {
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    opacity: 0.5;
  }

  .live-results-summary {
    font-size: 0.8rem;
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
  }

  /* Explore further section */
  .explore-section {
    margin-top: 3rem;
    margin-bottom: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .explore-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  .explore-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
