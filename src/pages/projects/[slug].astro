---
import ProjectLayout from '../../layouts/Project.astro';
import { projects } from '../../data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
};

const { project } = Astro.props;
---

<ProjectLayout title={project.title} description={project.tagline}>

  <!-- Back nav -->
  <div class="back-bar">
    <div class="container">
      <a href="/" class="back-link mono">← dean's list</a>
    </div>
  </div>

  <main class="container page">

    <!-- Header -->
    <header class="project-header">
      <div class="header-meta">
        <span class="mono muted category">{project.category}</span>
        <span class="mono muted sep">·</span>
        <span class="mono muted year">{project.year}</span>
        <span class="mono muted sep">·</span>
        <span class:list={['mono', 'status-badge', `status--${project.status}`]}>
          {project.status === 'live' ? '● live'
           : project.status === 'paused' ? '◌ paused'
           : '✓ complete'}
        </span>
      </div>

      <h1 class="project-title">{project.title}</h1>

      <p class="project-tagline muted">{project.tagline}</p>

      {project.statusNote && (
        <div class="status-note mono muted">{project.statusNote}</div>
      )}

      <a href={project.githubUrl} target="_blank" rel="noopener" class="github-link mono">
        view on github ↗
      </a>
    </header>

    <!-- Architecture diagram placeholder -->
    <!-- Claude Code: replace this with an SVG diagram for each project -->
    <div class="diagram-frame">
      <div class="diagram-label mono muted">architecture</div>
      <div class="diagram-placeholder mono muted">
        [ diagram — see SPEC.md for instructions ]
      </div>
    </div>

    <!-- Body -->
    <div class="project-body">

      <div class="section">
        <div class="section-label mono muted">problem</div>
        <p>{project.problem}</p>
      </div>

      <div class="section">
        <div class="section-label mono muted">what i built</div>
        <p>{project.what}</p>
      </div>

      <div class="section">
        <div class="section-label mono muted">highlights</div>
        <ul class="highlights">
          {project.highlights.map((h) => (
            <li>
              <span class="accent mono">→</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="section">
        <div class="section-label mono muted">stack</div>
        <div class="tags">
          {project.techStack.map((t) => (
            <span class="tag mono">{t}</span>
          ))}
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="page-footer">
      <a href="/" class="mono muted">← all projects</a>
      <a href={project.githubUrl} target="_blank" rel="noopener" class="mono accent">
        github ↗
      </a>
    </div>

  </main>
</ProjectLayout>

<style>
  /* Back bar */
  .back-bar {
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  .back-link {
    font-size: 0.8125rem;
    color: var(--muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  /* Page */
  .page {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }

  /* Header */
  .project-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2.5rem;
  }

  .header-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
  }

  .sep { opacity: 0.3; }
  .category { text-transform: uppercase; letter-spacing: 0.12em; }

  .status--live    { color: #4ade80; }
  .status--paused  { color: var(--muted); }
  .status--complete{ color: var(--muted); }

  .project-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .project-tagline {
    font-size: 1rem;
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 1rem;
  }

  .status-note {
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: var(--bg-card);
    border-left: 2px solid var(--border);
    border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: 1rem;
    max-width: 600px;
  }

  .github-link {
    font-size: 0.875rem;
    display: inline-block;
    margin-top: 0.5rem;
    border: 1px solid var(--accent-dim);
    padding: 0.4rem 0.875rem;
    border-radius: var(--radius);
    transition: background 0.15s;
  }

  .github-link:hover {
    background: var(--accent-dim);
    text-decoration: none;
  }

  /* Diagram frame */
  .diagram-frame {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 3rem;
  }

  .diagram-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 0.6;
  }

  .diagram-placeholder {
    font-size: 0.8125rem;
    opacity: 0.4;
    text-align: center;
    padding: 2rem 0;
    border: 1px dashed var(--border);
    border-radius: var(--radius);
  }

  /* Body sections */
  .project-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
    opacity: 0.6;
  }

  .section p {
    color: var(--muted);
    font-size: 0.9375rem;
    line-height: 1.8;
    max-width: 700px;
  }

  /* Highlights */
  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .highlights li {
    display: flex;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 700px;
  }

  .highlights li .mono {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Tags */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.6875rem;
    color: var(--muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 0.25rem 0.6rem;
    letter-spacing: 0.04em;
  }

  /* Page footer */
  .page-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .page-footer a {
    font-size: 0.8125rem;
  }
</style>
