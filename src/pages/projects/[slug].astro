---
import ProjectLayout from '../../layouts/Project.astro';
import { projects } from '../../data/projects';
import { fetchKitchenSync, fetchMusicPipeline, fetchWgups } from '../../lib/fetchProjectData';
import KitchenSyncChart from '../../components/charts/KitchenSyncChart';
import WgupsConvergenceChart from '../../components/charts/WgupsConvergenceChart';
import type { GetStaticPaths } from 'astro';
export const getStaticPaths: GetStaticPaths = () => {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
};

const { project } = Astro.props;

const kitchenResult = project.slug === 'kitchensync' ? await fetchKitchenSync() : { state: 'omitted' as const };
const musicResult = project.slug === 'music-growth-pipeline' ? await fetchMusicPipeline() : { state: 'omitted' as const };
const wgupsResult = project.slug === 'package-router' ? await fetchWgups() : { state: 'omitted' as const };

const abData = kitchenResult.state === 'ok' ? kitchenResult.data : null;
const pipelineStats = musicResult.state === 'ok' ? musicResult.data : null;
const wgupsData = wgupsResult.state === 'ok' ? wgupsResult.data : null;

const convergenceData = wgupsData ? {
  generations: wgupsData.convergence.map((c) => c.generation),
  scores: wgupsData.convergence.map((c) => c.score),
} : null;

let wasteDeltaPp: number | null = null;
let latestDay: {
  date: string;
  ml: { waste_pct: number; service_level: number };
  baseline: { waste_pct: number; service_level: number };
} | null = null;

const chartData = abData ? {
  dates: abData.daily.map((d) => d.date),
  mlSvc: abData.daily.map((d) => (d.ml.units_sold / (d.ml.units_sold + d.ml.stockouts)) * 100),
  baseSvc: abData.daily.map((d) => (d.baseline.units_sold / (d.baseline.units_sold + d.baseline.stockouts)) * 100),
  mlWaste: abData.daily.map((d) => (d.ml.waste_cost / d.ml.sales_revenue) * 100),
  baseWaste: abData.daily.map((d) => (d.baseline.waste_cost / d.baseline.sales_revenue) * 100),
} : null;

// TODO: fill in once Streamlit URL is confirmed
const STREAMLIT_URL: string | null = null;

if (abData) {
  wasteDeltaPp = abData.cumulative.ml_avg_waste_pct - abData.cumulative.baseline_avg_waste_pct;
  const d = abData.daily[abData.daily.length - 1];
  if (d) {
    latestDay = {
      date: d.date,
      ml: {
        waste_pct: (d.ml.waste_cost / d.ml.sales_revenue) * 100,
        service_level: (d.ml.units_sold / (d.ml.units_sold + d.ml.stockouts)) * 100,
      },
      baseline: {
        waste_pct: (d.baseline.waste_cost / d.baseline.sales_revenue) * 100,
        service_level: (d.baseline.units_sold / (d.baseline.units_sold + d.baseline.stockouts)) * 100,
      },
    };
  }
}
---

<ProjectLayout title={project.title} description={project.tagline}>

  <!-- Back nav -->
  <div class="back-bar">
    <div class="container">
      <a href="/" class="back-link mono">← dean's list</a>
    </div>
  </div>

  <main class="container page">

    <!-- Header -->
    <header class="project-header">
      <div class="header-meta">
        <span class="mono muted category">{project.category}</span>
        <span class="mono muted sep">·</span>
        <span class="mono muted year">{project.year}</span>
        <span class="mono muted sep">·</span>
        <span class:list={['mono', 'status-badge', `status--${project.status}`]}>
          {project.status === 'live' ? '● live'
           : project.status === 'paused' ? '◌ paused'
           : '✓ complete'}
        </span>
      </div>

      <h1 class="project-title">{project.title}</h1>

      <p class="project-tagline">{project.tagline}</p>

      {project.statusNote && (
        <div class="status-note mono muted">{project.statusNote}</div>
      )}

      <a href={project.githubUrl} target="_blank" rel="noopener" class="github-link mono">
        view on github ↗
      </a>
    </header>

    <!-- Live results chart (package-router only) -->
    {project.slug === 'package-router' && convergenceData && (
      <div class="live-results-section">
        <div class="live-results-header">
          <span class="section-label mono muted">live results</span>
          <span class="mono muted live-results-days">run {wgupsData!.run_timestamp.slice(0, 10)}</span>
        </div>
        <div class="live-results-summary mono muted">
          final fitness score {wgupsData!.final_score.toFixed(1)} · {wgupsData!.parameters.packages} packages · {wgupsData!.parameters.trucks} trucks · converged at generation {convergenceData.generations.at(-1)}
        </div>
        <WgupsConvergenceChart
          generations={convergenceData.generations}
          scores={convergenceData.scores}
          client:visible
        />
      </div>
    )}

    <!-- Live results chart (kitchensync only) -->
    {project.slug === 'kitchensync' && chartData && (
      <div class="live-results-section">
        <div class="live-results-header">
          <span class="section-label mono muted">live results</span>
          <span class="mono muted live-results-days">day {abData!.cumulative.days_run} of a/b test</span>
        </div>
        <div class="live-results-summary mono muted">
          {chartData.dates[0]} through {chartData.dates.at(-1)}
        </div>
        <KitchenSyncChart
          dates={chartData.dates}
          mlSvc={chartData.mlSvc}
          baseSvc={chartData.baseSvc}
          mlWaste={chartData.mlWaste}
          baseWaste={chartData.baseWaste}
          client:visible
        />
      </div>
    )}

    <!-- A/B Results (kitchensync only) -->
    {project.slug === 'kitchensync' && abData && (
      <div class="ab-section">
        <div class="ab-header">
          <span class="section-label mono muted">cumulative stats</span>
          <span class="ab-days mono muted">day {abData.cumulative.days_run}</span>
        </div>
        <div class="ab-grid">
          <div class="ab-card">
            <div class="ab-card-label mono">ml model</div>
            <div class="ab-metric">
              <span class="ab-value accent">{abData.cumulative.ml_avg_waste_pct.toFixed(1)}%</span>
              <span class="ab-key mono muted">avg waste</span>
            </div>
            <div class="ab-metric">
              <span class="ab-value">{abData.cumulative.ml_avg_service_level.toFixed(1)}%</span>
              <span class="ab-key mono muted">service level</span>
            </div>
          </div>
          <div class="ab-card">
            <div class="ab-card-label mono muted">baseline</div>
            <div class="ab-metric">
              <span class="ab-value">{abData.cumulative.baseline_avg_waste_pct.toFixed(1)}%</span>
              <span class="ab-key mono muted">avg waste</span>
            </div>
            <div class="ab-metric">
              <span class="ab-value">{abData.cumulative.base_avg_service_level.toFixed(1)}%</span>
              <span class="ab-key mono muted">service level</span>
            </div>
          </div>
        </div>
        {latestDay && (
          <div class="ab-daily">
            <div class="ab-daily-label mono muted">latest run · {latestDay.date}</div>
            <div class="ab-grid">
              <div class="ab-card">
                <div class="ab-card-label mono">ml model</div>
                <div class="ab-metric">
                  <span class="ab-value accent">{latestDay.ml.waste_pct.toFixed(1)}%</span>
                  <span class="ab-key mono muted">
                    waste
                    <span class:list={['delta', latestDay.ml.waste_pct < abData!.cumulative.ml_avg_waste_pct ? 'delta--better' : 'delta--worse']}>
                      {(latestDay.ml.waste_pct - abData!.cumulative.ml_avg_waste_pct) >= 0 ? '+' : ''}{(latestDay.ml.waste_pct - abData!.cumulative.ml_avg_waste_pct).toFixed(1)}pp vs avg
                    </span>
                  </span>
                </div>
                <div class="ab-metric">
                  <span class="ab-value">{latestDay.ml.service_level.toFixed(1)}%</span>
                  <span class="ab-key mono muted">
                    service level
                    <span class:list={['delta', latestDay.ml.service_level > abData!.cumulative.ml_avg_service_level ? 'delta--better' : 'delta--worse']}>
                      {(latestDay.ml.service_level - abData!.cumulative.ml_avg_service_level) >= 0 ? '+' : ''}{(latestDay.ml.service_level - abData!.cumulative.ml_avg_service_level).toFixed(1)}pp vs avg
                    </span>
                  </span>
                </div>
              </div>
              <div class="ab-card">
                <div class="ab-card-label mono muted">baseline</div>
                <div class="ab-metric">
                  <span class="ab-value">{latestDay.baseline.waste_pct.toFixed(1)}%</span>
                  <span class="ab-key mono muted">
                    waste
                    <span class:list={['delta', latestDay.baseline.waste_pct < abData!.cumulative.baseline_avg_waste_pct ? 'delta--better' : 'delta--worse']}>
                      {(latestDay.baseline.waste_pct - abData!.cumulative.baseline_avg_waste_pct) >= 0 ? '+' : ''}{(latestDay.baseline.waste_pct - abData!.cumulative.baseline_avg_waste_pct).toFixed(1)}pp vs avg
                    </span>
                  </span>
                </div>
                <div class="ab-metric">
                  <span class="ab-value">{latestDay.baseline.service_level.toFixed(1)}%</span>
                  <span class="ab-key mono muted">
                    service level
                    <span class:list={['delta', latestDay.baseline.service_level > abData!.cumulative.base_avg_service_level ? 'delta--better' : 'delta--worse']}>
                      {(latestDay.baseline.service_level - abData!.cumulative.base_avg_service_level) >= 0 ? '+' : ''}{(latestDay.baseline.service_level - abData!.cumulative.base_avg_service_level).toFixed(1)}pp vs avg
                    </span>
                  </span>
                </div>
              </div>
            </div>
          </div>
        )}

        <div class="ab-callout mono">
          {`ML lifts service level +${(abData.cumulative.ml_avg_service_level - abData.cumulative.base_avg_service_level).toFixed(1)}pp but adds +${wasteDeltaPp!.toFixed(1)}pp waste — the trade-off is the point.`}
        </div>
      </div>
    )}

    <!-- Pipeline Stats (music-growth-pipeline only) -->
    {project.slug === 'music-growth-pipeline' && pipelineStats && (
      <div class="ab-section">
        <div class="ab-header">
          <span class="section-label mono muted">live pipeline data</span>
          <span class="ab-days mono muted">{pipelineStats.summary.weeks_tracked} weeks of data · updated {pipelineStats.summary.latest_snapshot}</span>
        </div>

        <div class="ab-grid">
          {pipelineStats.growth_by_tier.filter(t => t.tier === 'mainstream').map(t => (
            <div class="ab-card">
              <div class="ab-card-label mono muted">mainstream · pages 1–50</div>
              <div class="ab-metric">
                <span class="ab-value">{t.median_pct_growth.toFixed(2)}%</span>
                <span class="ab-key mono muted">median 7-week growth</span>
              </div>
              <div class="ab-metric">
                <span class="ab-value">{t.p90_pct_growth.toFixed(2)}%</span>
                <span class="ab-key mono muted">p90 growth</span>
              </div>
            </div>
          ))}
          {pipelineStats.growth_by_tier.filter(t => t.tier === 'indie').map(t => (
            <div class="ab-card">
              <div class="ab-card-label mono accent">indie · pages 51+</div>
              <div class="ab-metric">
                <span class="ab-value accent">{t.median_pct_growth.toFixed(2)}%</span>
                <span class="ab-key mono muted">median 7-week growth</span>
              </div>
              <div class="ab-metric">
                <span class="ab-value accent">{t.p90_pct_growth.toFixed(2)}%</span>
                <span class="ab-key mono muted">p90 growth</span>
              </div>
            </div>
          ))}
        </div>

        <div class="ab-daily">
          <div class="ab-daily-label mono muted">fastest-growing indie artists · {pipelineStats.summary.latest_snapshot}</div>
          <div class="growth-list">
            {pipelineStats.top_growing_artists.slice(0, 5).map(a => (
              <div class="growth-row">
                <span class="growth-name mono">{a.artist_name}</span>
                <span class="growth-meta mono muted">pg {a.min_page}</span>
                <span class="growth-value mono accent">+{a.total_pct_growth.toFixed(1)}%</span>
              </div>
            ))}
          </div>
        </div>

        <div class="ab-callout mono">
          {(() => {
            const indie = pipelineStats!.growth_by_tier.find(t => t.tier === 'indie');
            const mainstream = pipelineStats!.growth_by_tier.find(t => t.tier === 'mainstream');
            const ratio = indie && mainstream ? (indie.p90_pct_growth / mainstream.p90_pct_growth).toFixed(1) : '—';
            return `Underground artists show ${indie?.p90_pct_growth.toFixed(1)}% P90 growth — ${ratio}× higher than mainstream (${mainstream?.p90_pct_growth.toFixed(1)}%). ${pipelineStats!.summary.artist_count.toLocaleString()} artists tracked.`;
          })()}
        </div>
      </div>
    )}

    <!-- Power BI Report Preview (music-growth-pipeline only) -->
    {project.slug === 'music-growth-pipeline' && (
      <div class="report-section">
        <div class="report-header">
          <span class="section-label mono muted">power bi report</span>
        </div>
        <div class="report-grid">
          <a href="/powerbi/music-growth-main.png" target="_blank" rel="noopener" class="report-card">
            <div class="report-card-label mono muted">main dashboard</div>
            <img src="/powerbi/music-growth-main.png" alt="Music Growth Pipeline — main Power BI dashboard" class="report-img" />
          </a>
          <a href="/powerbi/music-growth-drillthrough.png" target="_blank" rel="noopener" class="report-card">
            <div class="report-card-label mono muted">artist drill-through</div>
            <img src="/powerbi/music-growth-drillthrough.png" alt="Music Growth Pipeline — artist drill-through Power BI page" class="report-img" />
          </a>
        </div>
      </div>
    )}

    <div class="diagram-frame">
      <div class="diagram-label mono muted">how it's built</div>

      {project.slug === 'kitchensync' && (
        <svg width="100%" viewBox="0 0 560 750" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          {/* POS Simulator */}
          <rect x="170" y="10" width="220" height="38" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="280" y="29" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">POS Simulator — EC2</text>
          <line x1="280" y1="48" x2="280" y2="80" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,80 280,87 284,80" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="288" y="64" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">POST /sales, /waste, /stockout</text>
          {/* FastAPI */}
          <rect x="150" y="87" width="260" height="38" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="280" y="106" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">FastAPI Ingest API — EC2</text>
          <line x1="280" y1="125" x2="280" y2="157" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,157 280,164 284,157" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          {/* Neon Postgres */}
          <rect x="80" y="164" width="400" height="38" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="280" y="183" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Neon Postgres — 12 store schemas</text>
          <line x1="280" y1="202" x2="280" y2="242" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,242 280,249 284,242" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="288" y="219" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">2am UTC · extract_to_snowflake.py</text>
          {/* Snowflake */}
          <rect x="170" y="249" width="220" height="38" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="280" y="268" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Snowflake — KS_DB.RAW</text>
          <line x1="280" y1="287" x2="280" y2="322" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,322 280,329 284,322" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="288" y="305" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">dbt Core</text>
          {/* dbt pipeline */}
          <rect x="50" y="329" width="460" height="55" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
          <text x="280" y="349" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">Staging → Intermediate → Marts</text>
          <text x="280" y="368" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">stg · int_rolling_features · mart_waste · mart_predictions</text>
          <line x1="280" y1="384" x2="280" y2="412" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,412 280,419 284,412" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          {/* LightGBM */}
          <rect x="170" y="419" width="220" height="38" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="280" y="438" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">LightGBM — 338,688 preds</text>
          {/* Split */}
          <line x1="280" y1="457" x2="280" y2="490" stroke="#7a7f87" stroke-width="1.5"/>
          <line x1="130" y1="490" x2="430" y2="490" stroke="#7a7f87" stroke-width="1.5"/>
          <line x1="130" y1="490" x2="130" y2="522" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="126,522 130,529 134,522" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <line x1="430" y1="490" x2="430" y2="522" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="426,522 430,529 434,522" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          {/* Streamlit (left) */}
          <rect x="20" y="529" width="220" height="55" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="130" y="549" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">Streamlit Dashboard</text>
          <text x="130" y="568" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">Kitchen + Chicken · 5min refresh</text>
          {/* A/B Comparison (right) */}
          <rect x="320" y="529" width="220" height="55" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="430" y="549" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">A/B Comparison</text>
          <text x="430" y="568" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">ML vs baseline · seeded demand</text>
          <line x1="430" y1="584" x2="430" y2="618" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="426,618 430,625 434,618" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="438" y="602" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">git commit + push</text>
          {/* ab_results.json */}
          <rect x="320" y="625" width="220" height="35" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
          <text x="430" y="642" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">data/ab_results.json</text>
          <line x1="430" y1="660" x2="430" y2="693" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="426,693 430,700 434,693" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="430" y="677" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">nightly rebuild · 3:30am UTC</text>
          {/* Astro Portfolio */}
          <rect x="305" y="700" width="250" height="35" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="430" y="717" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">Astro Portfolio — deanslist.dev</text>
        </svg>
      )}

      {project.slug === 'music-growth-pipeline' && (
        <svg width="100%" viewBox="0 0 480 560" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          {/* Last.fm API */}
          <rect x="60" y="10" width="360" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="30" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Last.fm API — chart.getTopArtists</text>
          <line x1="240" y1="50" x2="240" y2="93" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,93 240,100 244,93" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="73" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">seed_artists.py · snapshot_artists.py</text>
          {/* Neon Postgres */}
          <rect x="80" y="100" width="320" height="55" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="120" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Neon Postgres</text>
          <text x="240" y="139" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">artists · weekly_charts · snapshots · genres</text>
          <line x1="240" y1="155" x2="240" y2="208" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,208 240,215 244,208" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="184" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">dbt-postgres · Sunday 9am UTC</text>
          {/* dbt marts */}
          <rect x="40" y="215" width="400" height="55" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
