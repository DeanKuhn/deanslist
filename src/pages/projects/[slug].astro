---
import ProjectLayout from '../../layouts/Project.astro';
import { projects } from '../../data/projects';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { project: p },
  }));
};

const { project } = Astro.props;
---

<ProjectLayout title={project.title} description={project.tagline}>

  <!-- Back nav -->
  <div class="back-bar">
    <div class="container">
      <a href="/" class="back-link mono">← dean's list</a>
    </div>
  </div>

  <main class="container page">

    <!-- Header -->
    <header class="project-header">
      <div class="header-meta">
        <span class="mono muted category">{project.category}</span>
        <span class="mono muted sep">·</span>
        <span class="mono muted year">{project.year}</span>
        <span class="mono muted sep">·</span>
        <span class:list={['mono', 'status-badge', `status--${project.status}`]}>
          {project.status === 'live' ? '● live'
           : project.status === 'paused' ? '◌ paused'
           : '✓ complete'}
        </span>
      </div>

      <h1 class="project-title">{project.title}</h1>

      <p class="project-tagline muted">{project.tagline}</p>

      {project.statusNote && (
        <div class="status-note mono muted">{project.statusNote}</div>
      )}

      <a href={project.githubUrl} target="_blank" rel="noopener" class="github-link mono">
        view on github ↗
      </a>
    </header>

    <div class="diagram-frame">
      <div class="diagram-label mono muted">architecture</div>

      {project.slug === 'kitchensync' && (
        <svg width="100%" viewBox="0 0 480 560" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="130" y="10" width="220" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="30" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">POS Simulator</text>
          <line x1="240" y1="50" x2="240" y2="83" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,83 240,90 244,83" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="70" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">POST /sale</text>
          <rect x="110" y="90" width="260" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="110" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">FastAPI Ingest API</text>
          <line x1="240" y1="130" x2="240" y2="163" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,163 240,170 244,163" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="50" y="170" width="380" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="190" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Neon Postgres — 12 store schemas</text>
          <line x1="240" y1="210" x2="240" y2="253" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,253 240,260 244,253" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="232" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">extract_to_snowflake.py</text>
          <rect x="130" y="260" width="220" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="280" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Snowflake RAW</text>
          <line x1="240" y1="300" x2="240" y2="343" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,343 240,350 244,343" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="323" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">dbt Core</text>
          <rect x="20" y="350" width="440" height="55" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
          <text x="240" y="370" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Staging → Intermediate → Marts → Metrics</text>
          <text x="240" y="389" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">3-layer dbt transform</text>
          <line x1="240" y1="405" x2="240" y2="428" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,428 240,435 244,428" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="120" y="435" width="240" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="455" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">LightGBM Model</text>
          <line x1="240" y1="475" x2="240" y2="508" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,508 240,515 244,508" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="50" y="515" width="380" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="535" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Streamlit Dashboard — 60s refresh</text>
        </svg>
      )}

      {project.slug === 'music-growth-pipeline' && (
        <svg width="100%" viewBox="0 0 480 460" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="60" y="10" width="360" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="30" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Last.fm API — chart.getTopArtists</text>
          <line x1="240" y1="50" x2="240" y2="93" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,93 240,100 244,93" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="73" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">seed_artists.py</text>
          <rect x="80" y="100" width="320" height="55" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="120" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Neon Postgres</text>
          <text x="240" y="139" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">artists · weekly_charts · snapshots · tags</text>
          <line x1="240" y1="155" x2="240" y2="208" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,208 240,215 244,208" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="184" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">dbt-postgres</text>
          <rect x="40" y="215" width="400" height="55" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
          <text x="240" y="235" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Staging → Marts</text>
          <text x="240" y="253" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">artist_tiers · genre_stats · artist_similarity_network</text>
          <line x1="240" y1="270" x2="240" y2="323" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,323 240,330 244,323" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="299" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">GitHub Actions — weekly cron</text>
          <rect x="80" y="330" width="320" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="350" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">GitHub Actions (Sunday 9AM UTC)</text>
          <line x1="240" y1="370" x2="240" y2="403" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,403 240,410 244,403" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="100" y="410" width="280" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="430" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">analysis.sql</text>
        </svg>
      )}

      {project.slug === 'market-cynic-pipeline' && (
        <svg width="100%" viewBox="0 0 560 500" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="30" y="10" width="220" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="140" y="30" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">Yahoo Finance (Playwright)</text>
          <rect x="310" y="10" width="220" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="420" y="30" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">Reddit — 4 subreddits</text>
          <line x1="140" y1="50" x2="140" y2="83" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="136,83 140,90 144,83" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <line x1="420" y1="50" x2="420" y2="83" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="416,83 420,90 424,83" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="30" y="90" width="220" height="50" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
          <text x="140" y="108" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">Bronze layer</text>
          <text x="140" y="126" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">raw_stocks.json</text>
          <rect x="310" y="90" width="220" height="50" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
          <text x="420" y="108" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="11" font-family="IBM Plex Mono, monospace">Bronze layer</text>
          <text x="420" y="126" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">Reddit posts + VADER</text>
          <polyline points="140,140 140,185 280,185" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="420,140 420,185 280,185" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <line x1="280" y1="185" x2="280" y2="203" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,203 280,210 284,203" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="80" y="210" width="400" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="280" y="230" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Silver — Pydantic validation</text>
          <line x1="280" y1="250" x2="280" y2="283" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,283 280,290 284,283" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="60" y="290" width="440" height="55" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="280" y="310" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Gold — divergence detection</text>
          <text x="280" y="328" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">sentiment_momentum &gt; 0 AND price_momentum &lt; 0</text>
          <line x1="280" y1="345" x2="280" y2="368" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,368 280,375 284,368" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="100" y="375" width="360" height="40" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
          <text x="280" y="395" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">market_history.parquet (append-only)</text>
          <line x1="280" y1="415" x2="280" y2="448" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="276,448 280,455 284,448" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="120" y="455" width="320" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="280" y="475" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Streamlit Dashboard</text>
        </svg>
      )}

      {project.slug === 'package-router' && (
        <svg width="100%" viewBox="0 0 480 545" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="90" y="10" width="300" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="30" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Random package generation</text>
          <line x1="240" y1="50" x2="240" y2="83" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,83 240,90 244,83" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="50" y="90" width="380" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="110" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Population init — capacity-aware seeding</text>
          <line x1="240" y1="130" x2="240" y2="173" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,173 240,180 244,173" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="60" y="180" width="360" height="55" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="200" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">Fitness function</text>
          <text x="240" y="219" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">distance_score + deadline_penalty + capacity</text>
          <line x1="240" y1="235" x2="240" y2="298" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,298 240,305 244,298" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <text x="248" y="261" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">repeat until convergence</text>
          <text x="248" y="276" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">or 500 stagnant generations</text>
          <rect x="50" y="305" width="380" height="55" rx="2" fill="#0e0f11" stroke="#2a2d32" stroke-width="1.5"/>
          <text x="240" y="325" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Selection → Crossover (OX) → Mutation</text>
          <text x="240" y="343" text-anchor="middle" dominant-baseline="middle" fill="#7a7f87" font-size="10" font-family="IBM Plex Mono, monospace">swap | scramble | inversion + adaptive rate</text>
          <line x1="240" y1="360" x2="240" y2="413" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,413 240,420 244,413" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="50" y="420" width="380" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="440" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="12" font-family="IBM Plex Mono, monospace">Best chromosome → delivery routes per truck</text>
          <line x1="240" y1="460" x2="240" y2="493" stroke="#7a7f87" stroke-width="1.5"/>
          <polyline points="236,493 240,500 244,493" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="100" y="500" width="280" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="520" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">CLI — status lookup by ID</text>
        </svg>
      )}

    </div>

    <!-- Body -->
    <div class="project-body">

      <div class="section">
        <div class="section-label mono muted">problem</div>
        <p>{project.problem}</p>
      </div>

      <div class="section">
        <div class="section-label mono muted">what i built</div>
        <p>{project.what}</p>
      </div>

      <div class="section">
        <div class="section-label mono muted">highlights</div>
        <ul class="highlights">
          {project.highlights.map((h) => (
            <li>
              <span class="accent mono">→</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="section">
        <div class="section-label mono muted">stack</div>
        <div class="tags">
          {project.techStack.map((t) => (
            <span class="tag mono">{t}</span>
          ))}
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="page-footer">
      <a href="/" class="mono muted">← all projects</a>
      <a href={project.githubUrl} target="_blank" rel="noopener" class="mono accent">
        github ↗
      </a>
    </div>

  </main>
</ProjectLayout>

<style>
  /* Back bar */
  .back-bar {
    border-bottom: 1px solid var(--border);
    padding: 0.75rem 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }

  .back-link {
    font-size: 0.8125rem;
    color: var(--muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  /* Page */
  .page {
    padding-top: 4rem;
    padding-bottom: 6rem;
  }

  /* Header */
  .project-header {
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 2.5rem;
  }

  .header-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 1rem;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
  }

  .sep { opacity: 0.3; }
  .category { text-transform: uppercase; letter-spacing: 0.12em; }

  .status--live    { color: #4ade80; }
  .status--paused  { color: var(--muted); }
  .status--complete{ color: var(--muted); }

  .project-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .project-tagline {
    font-size: 1rem;
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 1rem;
  }

  .status-note {
    font-size: 0.8rem;
    padding: 0.5rem 0.75rem;
    background: var(--bg-card);
    border-left: 2px solid var(--border);
    border-radius: 0 var(--radius) var(--radius) 0;
    margin-bottom: 1rem;
    max-width: 600px;
  }

  .github-link {
    font-size: 0.875rem;
    display: inline-block;
    margin-top: 0.5rem;
    border: 1px solid var(--accent-dim);
    padding: 0.4rem 0.875rem;
    border-radius: var(--radius);
    transition: background 0.15s;
  }

  .github-link:hover {
    background: var(--accent-dim);
    text-decoration: none;
  }

  /* Diagram frame */
  .diagram-frame {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    margin-bottom: 3rem;
  }

  .diagram-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 0.6;
  }

  /* Body sections */
  .project-body {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .section-label {
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.625rem;
    opacity: 0.6;
  }

  .section p {
    color: var(--muted);
    font-size: 0.9375rem;
    line-height: 1.8;
    max-width: 700px;
  }

  /* Highlights */
  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .highlights li {
    display: flex;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.65;
    max-width: 700px;
  }

  .highlights li .mono {
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  /* Tags */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    font-size: 0.6875rem;
    color: var(--muted);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 0.25rem 0.6rem;
    letter-spacing: 0.04em;
  }

  /* Page footer */
  .page-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
