          <polyline points="236,493 240,500 244,493" fill="none" stroke="#7a7f87" stroke-width="1.5"/>
          <rect x="100" y="500" width="280" height="40" rx="2" fill="#0e0f11" stroke="#f06a00" stroke-width="1.5"/>
          <text x="240" y="520" text-anchor="middle" dominant-baseline="middle" fill="#e8e9ea" font-size="13" font-family="IBM Plex Mono, monospace">CLI — status lookup by ID</text>
        </svg>
      )}

    </div>

    <!-- Body -->
    <div class="project-body">

      <div class="section">
        <div class="section-label mono muted">problem</div>
        <p>{project.problem}</p>
      </div>

      <div class="section">
        <div class="section-label mono muted">what i built</div>
        <p>{project.what}</p>
      </div>

      <div class="section">
        <div class="section-label mono muted">highlights</div>
        <ul class="highlights">
          {project.highlights.map((h) => (
            <li>
              <span class="accent mono">→</span>
              <span>{h}</span>
            </li>
          ))}
        </ul>
      </div>

      {project.challenges && (
        <div class="section section--challenges">
          <div class="section-label mono muted">what i learned the hard way</div>
          <p>{project.challenges}</p>
        </div>
      )}

      <div class="section">
        <div class="section-label mono muted">stack</div>
        <div class="tags">
          {project.techStack.map((t) => (
            <span class="tag mono">{t}</span>
          ))}
        </div>
      </div>

    </div>

    <!-- Footer -->
    <div class="page-footer">
      <a href="/" class="mono muted">← all projects</a>
      <a href={project.githubUrl} target="_blank" rel="noopener" class="mono accent">
        github ↗
      </a>
    </div>

  </main>
</ProjectLayout>

